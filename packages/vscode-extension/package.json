{
  "name": "@phoenixaihub/vscode-security-scanner",
  "displayName": "AI Security Scanner",
  "description": "AI-native vulnerability scanner — finds bugs, explains exploits, and fixes code inline.",
  "version": "0.1.0",
  "publisher": "ai-security-scanner",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:python",
    "onLanguage:ruby",
    "onLanguage:go",
    "onLanguage:java",
    "onLanguage:rust",
    "onLanguage:html"
  ],
  "type": "commonjs",
  "main": "./dist/extension.js",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist .tsbuildinfo",
    "package": "npx @vscode/vsce package"
  },
  "dependencies": {
    "@ai-security-scanner/core": "*"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^5.7.0"
  },
  "contributes": {
    "commands": [
      {
        "command": "aiSecurityScanner.scanFile",
        "title": "AI Security Scanner: Scan Current File"
      },
      {
        "command": "aiSecurityScanner.scanWorkspace",
        "title": "AI Security Scanner: Scan Workspace"
      }
    ],
    "configuration": {
      "title": "AI Security Scanner",
      "properties": {
        "aiSecurityScanner.enableOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Run scanner automatically on file save."
        },
        "aiSecurityScanner.enableOnType": {
          "type": "boolean",
          "default": false,
          "description": "Run scanner as you type (may impact performance)."
        },
        "aiSecurityScanner.llm.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for LLM-powered explanations and fix suggestions."
        },
        "aiSecurityScanner.llm.baseUrl": {
          "type": "string",
          "default": "https://api.openai.com/v1",
          "description": "Base URL for the OpenAI-compatible LLM API."
        },
        "aiSecurityScanner.llm.model": {
          "type": "string",
          "default": "gpt-4o-mini",
          "description": "LLM model to use for explanations."
        }
      }
    }
  }
}
